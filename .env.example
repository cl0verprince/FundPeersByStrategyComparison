# Copy this file to .env and fill in real values.
# NEVER commit the real .env — only this template (key names, no values).

# SEC requires a descriptive User-Agent with contact info on all requests
# (e.g. "FundsPeersStrategy you@example.com")
SEC_USER_AGENT=

# LM Studio local server (OpenAI-compatible API), used to run phi-4 for narration
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio
